{
  "manifest_version": 3,
  "name": "SPS Privacy Scanner",
  "short_name": "SPS",
  "version": "1.0.0",
  "description": "Shows the Seglamater Privacy Standard grade for every website you visit.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "SPS Privacy Grade"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://seglamater.app/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sps@seglamater.app",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "urlbar_data_collection": false,
        "private_browsing_data_collection": false,
        "required": ["none"]
      }
    }
  }
}
